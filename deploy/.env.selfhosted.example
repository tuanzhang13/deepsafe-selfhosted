# 深度云网络验证 DeepSafe — 自主部署版 Docker 配置（Ubuntu）
# 复制为 .env.selfhosted 后修改
# 推荐宿主机: Ubuntu 22.04 / 24.04 LTS

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=deepsafe
MYSQL_USER=deepsafe
MYSQL_PASSWORD=deepsafe

# 对外访问端口（管理端 + API 统一入口）
WEB_PORT=8088

JWT_SECRET=change-me-in-production

# 预编译镜像（客户仓库不含源码，仅拉取镜像部署）
DEEPSAFE_IMAGE_PREFIX=ghcr.io/tuanzhang13
DEEPSAFE_VERSION=latest
